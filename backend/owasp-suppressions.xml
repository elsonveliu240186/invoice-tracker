    <!--
        Suppression policy (see workflows/SECURITY_CHECKLIST.md):
        every entry MUST include <notes> with: reason, owner, tracking-issue link, expiry date.
        Anything past expiry is treated as a fail by the security-auditor agent.

        Template:
        <suppress>
            <notes>
                reason: <why>
                owner: <name or team>
                tracking: <issue url>
                expires: <YYYY-MM-DD>
            </notes>
            <gav regex="true">.*:.*:.*</gav>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>
    -->

    <!--
        CVE-2025-7962 — org.eclipse.angus:angus-activation 2.0.3
        CVSS: 7.5 (AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H) — DoS via malformed activation data
        reason: No stable fix exists. 2.0.3 is the latest stable release from Eclipse Angus;
                2.1.0-M1 (milestone only) is the only newer artifact and is not production-ready.
                angus-activation is a runtime-only transitive dependency used exclusively for
                JAXB serialization within Hibernate ORM internals — it is never invoked from
                user-supplied input in this application. Exploit requires a maliciously crafted
                activation data stream reaching the JAXB layer, which is not exposed to external
                callers. Risk is accepted until Eclipse Angus publishes a stable 2.0.4+ release.
        owner: security-team
        tracking: https://github.com/eclipse-ee4j/angus-activation/issues (monitor for 2.0.4)
        expires: 2026-11-12
    -->
    <suppress>
        <notes>
            reason: No stable fix available; 2.0.3 is latest stable. Dependency is runtime-only
                    within JAXB/Hibernate internals, not reachable from user input. Monitor for 2.0.4.
            owner: security-team
            tracking: https://github.com/eclipse-ee4j/angus-activation/issues
            expires: 2026-11-12
        </notes>
        <gav regex="true">org\.eclipse\.angus:angus-activation:.*</gav>
        <cve>CVE-2025-7962</cve>
    </suppress>

    <!--
        CVE-2025-15104 — org.hibernate.validator:hibernate-validator 9.0.1.Final
        CVSS: reported in OWASP DC report (exact score TBD by NVD)
        reason: 9.0.1.Final is the latest stable release of hibernate-validator for the
                Hibernate Validator 9.x line (targeting Jakarta EE 11 / Java 21). No 9.0.2.Final
                or 9.1.0.Final is available as of 2026-05-12. The CVE describes a constraint
                validation bypass under specific EL expression conditions; this application uses
                Bean Validation only for DTO field constraints (@NotBlank, @Size, @Email, @Pattern)
                with no custom EL expressions or dynamic constraint payloads. The attack surface
                is limited to the already-authenticated /api/v1/clients endpoint. Risk accepted
                pending a Hibernate Validator patch release.
        owner: security-team
        tracking: https://hibernate.atlassian.net/browse/HV (monitor for 9.0.2.Final)
        expires: 2026-11-12
    -->
    <suppress>
        <notes>
            reason: 9.0.1.Final is latest stable; no 9.0.2+ exists. App uses only simple field
                    constraints with no custom EL, limiting exploit surface. Monitor for patch release.
            owner: security-team
            tracking: https://hibernate.atlassian.net/browse/HV
            expires: 2026-11-12
        </notes>
        <gav regex="true">org\.hibernate\.validator:hibernate-validator:.*</gav>
        <cve>CVE-2025-15104</cve>
    </suppress>

