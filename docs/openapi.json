  "info": {
    "title": "Invoice Tracker API",
    "version": "0.0.1",
    "description": "REST API for the invoice-tracker application. Regenerated from the live backend (/v3/api-docs) by the documentation agent on FEAT-20260516-01. Features: Auth with Bucket4j rate-limiting (5 req/IP/min on /auth/login and /auth/register), Clients CRUD, Invoice CRUD + PDF/DOCX artifact generation/download, Dashboard stats, Expense tracking CRUD + category summary. All protected endpoints require HTTP Basic authentication."
  },
