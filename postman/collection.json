    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            },
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"s3cr3tP@ss\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('response has email and displayName', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('email');",
                  "  pm.expect(body).to.have.property('displayName');",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const token = btoa(body.email + ':' + JSON.parse(pm.request.body.raw).password);",
                  "  pm.environment.set('authToken', token);",
                  "}"
                ]
              }
            }
          ]
        },
